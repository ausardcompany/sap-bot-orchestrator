{
  "name": "alexi",
  "version": "0.3.6",
  "type": "module",
  "description": "Alexi - Intelligent LLM orchestrator with multi-provider support and auto-routing",
  "main": "dist/index.js",
  "bin": {
    "alexi": "dist/cli/program.js",
    "ax": "dist/cli/program.js"
  },
  "scripts": {
    "dev": "tsx src/cli/program.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/program.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sap-ai-sdk/ai-api": "^2.9.0",
    "@sap-ai-sdk/orchestration": "^2.9.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "duck-duck-scrape": "^2.2.7",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.8",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "nanoid": "^5.1.7",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "simple-git": "^3.33.0",
    "terminal-link": "^5.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "tsc-files": "^1.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [
    "llm",
    "ai",
    "orchestrator",
    "chatbot",
    "openai",
    "anthropic",
    "sap",
    "bedrock"
  ],
  "author": "Ausard",
  "license": "MIT"
}
