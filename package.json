{
  "name": "alexi",
  "version": "0.4.13",
  "type": "module",
  "description": "Alexi - Intelligent LLM orchestrator with multi-provider support and auto-routing",
  "main": "dist/index.js",
  "bin": {
    "alexi": "dist/cli/program.js",
    "ax": "dist/cli/program.js"
  },
  "scripts": {
    "dev": "tsx src/cli/program.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/program.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sap-ai-sdk/ai-api": "^2.9.0",
    "@sap-ai-sdk/orchestration": "^2.10.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "duck-duck-scrape": "^2.2.7",
    "fzf": "^0.5.2",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.16",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^18.0.3",
    "marked-terminal": "^7.3.0",
    "nanoid": "^5.1.11",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.5",
    "simple-git": "^3.36.0",
    "terminal-image": "^4.3.0",
    "terminal-link": "^5.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "puppeteer": "^24.42.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsc-files": "^1.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [
    "llm",
    "ai",
    "orchestrator",
    "chatbot",
    "openai",
    "anthropic",
    "sap",
    "bedrock"
  ],
  "author": "Ausard",
  "license": "MIT"
}
